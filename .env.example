# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# PostgreSQL (use these or DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag
DB_USER=postgres
DB_PASSWORD=postgres

# Alternative: full connection string (overrides individual DB_* vars)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag

# pgvector
PG_VECTOR_COLLECTION_NAME=documents

# PDF ingestion
PDF_PATH=
